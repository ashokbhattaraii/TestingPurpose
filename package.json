{
  "name": "workops",
  "version": "1.0.0",
  "private": true,
  "description": "WorkOps — Monorepo powered by Turborepo (Next.js + NestJS)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@workops/web",
    "dev:api": "turbo run dev --filter=@workops/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@workops/web",
    "build:api": "turbo run build --filter=@workops/api",
    "start": "turbo run start",
    "start:web": "turbo run start --filter=@workops/web",
    "start:api": "turbo run start --filter=@workops/api",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "migrate": "dotenv -e .env prisma migrate dev --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:push": "prisma db push --schema=apps/api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=apps/api/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "7",
    "axios": "^1.13.6",
    "jose": "^4.15.9",
    "pg": "^8.18.0",
    "prisma": "7",
    "react-feather": "^2.0.10",
    "react-icons": "^5.5.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/phoenix": "^1.6.7",
    "patch-package": "^8.0.1",
    "turbo": "^2.8.12"
  },
  "engines": {
    "node": ">=24.x"
  },
  "packageManager": "pnpm@10.4.0"
}