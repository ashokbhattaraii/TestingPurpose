generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  name                 String
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  address              String?
  bio                  String?
  department           String?
  emergencyContact     String?
  lastLoginAt          DateTime?
  phone                String?
  photoURL             String?
  position             String?
  startDate            DateTime?
  uid                  String             @unique
  updatedAt            DateTime           @updatedAt
  employment_type      String?
  job_title            String?
  org_unit             String?
  roles                String[]           @default(["employee"])
  cuid                 String?            @unique
  gender               String?
  phone_home           String?
  phone_recovery       String?
  phone_work           String?
  analytics            Analytics[]
  createdAnnouncements Announcement[]     @relation("AnnouncementCreator")
  connectedAccounts    ConnectedAccount[]
  lunchAttendance      LunchAttendance[]
  notifications        Notification[]
  approvedRequests     Request[]          @relation("RequestApprover")
  requests             Request[]

  @@index([uid])
  @@index([email])
}

model ConnectedAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Request {
  id              String                  @id @default(cuid())
  userId          String
  type            RequestType
  status          RequestStatus           @default(PENDING)
  title           String
  description     String?
  approverId      String?
  approvedAt      DateTime?
  rejectionReason String?
  adminNotes      String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  isAnonymous     Boolean                 @default(false)
  approver        User?                   @relation("RequestApprover", fields: [approverId], references: [id])
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  issueDetails    RequestIssueDetails?
  suppliesDetails RequestSuppliesDetails?

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model RequestIssueDetails {
  requestId            String        @id
  priority             IssuePriority
  category             IssueCategory
  location             String?
  otherCategoryDetails String?
  request              Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([priority])
  @@index([category])
}

model RequestSuppliesDetails {
  requestId            String           @id
  category             SuppliesCategory
  itemName             String
  otherCategoryDetails String?
  request              Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([category])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  priority    String    @default("normal")
  isPublished Boolean   @default(false)
  createdById String
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  targetRoles String[]
  pinned      Boolean   @default(false)
  createdBy   User      @relation("AnnouncementCreator", fields: [createdById], references: [id])

  @@index([isPublished])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  isRead    Boolean          @default(false)
  userId    String
  createdAt DateTime         @default(now())
  link      String?
  metadata  Json?
  readAt    DateTime?
  type      NotificationType
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model LunchAttendance {
  id                   String     @id @default(cuid())
  userId               String
  date                 DateTime   @db.Date
  isAttending          Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  preferredLunchOption LunchType?
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model Analytics {
  id        String   @id @default(cuid())
  userId    String?
  metric    String
  value     Float
  metadata  Json?
  date      DateTime @default(now())
  period    String   @default("daily")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metric])
  @@index([date])
  @@index([period])
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  REJECTED
  RESOLVED
  ON_HOLD
  CANCELLED
}

enum RequestType {
  ISSUE
  SUPPLIES
}

enum LunchType {
  VEG
  NON_VEG
  VEGAN
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueCategory {
  TECHNICAL
  FACILITY
  HR
  ADMINISTRATIVE
  SECURITY
  OTHER
}

enum SuppliesCategory {
  OFFICE_SUPPLIES
  EQUIPMENT
  STATIONERY
  PANTRY
  CLEANING
  TECHNOLOGY
  OTHER
}

enum NotificationType {
  REQUEST_UPDATE
  ANNOUNCEMENT
  SYSTEM
  MENTION
}
